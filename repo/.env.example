DATABASE_URL=postgres://civicsort:civicsort_secret@localhost:5432/civicsort
BIND_ADDRESS=0.0.0.0:8080
RUST_LOG=info

# Master key for field encryption (64 hex chars = 32 bytes)
# Generate with: openssl rand -hex 32
CIVICSORT_MASTER_KEY=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2

# Local directory for uploaded reference images
CIVICSORT_IMAGE_DIR=./data/images

# Local directory for exported payload files
CIVICSORT_EXPORT_DIR=./data/exports

# Set to "1" to allow first-user bootstrap registration without auth (empty DB only)
# Remove or set to "0" after initial admin is created
CIVICSORT_BOOTSTRAP_ADMIN=1
